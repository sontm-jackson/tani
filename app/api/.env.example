# Stellar network (testnet for the whole hackathon)
STELLAR_NETWORK=testnet
HORIZON_URL=https://horizon-testnet.stellar.org
FRIENDBOT_URL=https://friendbot.stellar.org

# Asset settled to farmers. On testnet we issue our own "USDC" from a demo issuer
# (production swaps in Circle's real USDC issuer). Filled in by `npm run seed`.
ASSET_CODE=USDC
ASSET_ISSUER=
ISSUER_SECRET=

# Demo anchor (cash-out). testanchor.stellar.org is the SDF reference anchor.
ANCHOR_HOME_DOMAIN=testanchor.stellar.org
# The anchor only settles its own USDC. This is testanchor's USDC issuer; cash-out swaps
# the farmer's internal USDC for this 1:1 before the SEP-24 withdraw.
ANCHOR_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# testanchor caps deposit/withdraw at 10 units per transaction.
ANCHOR_MAX_PER_TX=10
# Reserve account holding anchor USDC for the cash-out swap. Filled in by `npm run seed`.
TREASURY_SECRET=
TREASURY_PUBLIC=

# Server
PORT=4000

# DB
DATABASE_URL="file:./tani.db"

# Secret-at-rest encryption (AES-256-GCM). Auto-generated on first run.
ENCRYPTION_KEY=

# Session signing for phone-OTP login. Auto-generated on first run.
JWT_SECRET=
OTP_TTL_MINUTES=5

# SMS delivery for OTP codes. Leave all blank for dev mode (code logged + returned).
# Provider order: SpeedSMS (Vietnam) is used first, then Twilio.

# SpeedSMS.vn — Vietnamese gateway (recommended for VN delivery).
#   SPEEDSMS_SMS_TYPE: 4 = default notify brand (no own brandname needed),
#                      3 = your registered brandname (also set SPEEDSMS_SENDER).
SPEEDSMS_TOKEN=
SPEEDSMS_SMS_TYPE=4
SPEEDSMS_SENDER=

# Twilio — international fallback.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Firebase Phone Auth (recommended: free, no Vietnamese paperwork). When set, the
# farmer app uses Firebase for OTP and the backend verifies the ID token here.
# From Firebase console → Project settings → Service accounts → Generate private key.
# Keep the private key on one line with literal \n for newlines.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
