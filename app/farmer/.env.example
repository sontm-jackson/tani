# Production API origin (leave blank in dev — Vite proxies /api to localhost:4000).
# e.g. VITE_API_URL=https://api.tani.app
VITE_API_URL=

# Optional link to the cooperative dashboard shown in the header.
# Dev: VITE_PEER_URL=http://localhost:5173
VITE_PEER_URL=

# Firebase Phone Auth (from Firebase console → Project settings → Your apps → Web app).
# When set, the farmer app sends real OTP via Firebase. Leave blank for dev OTP.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
